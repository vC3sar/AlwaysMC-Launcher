{
  "name": "mc-beta",
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "build:win": "electron-builder --win nsis",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Offline/no premium Minecraft launcher with Mineflayer and Discord Rich Presence",
  "dependencies": {
    "@azure/msal-node": "^3.8.1",
    "@sentry/electron": "^7.13.0",
    "ansi-to-html": "^0.7.2",
    "discord-rpc": "^4.0.1",
    "fs": "^0.0.1-security",
    "https": "^1.0.0",
    "mineflayer": "^4.37.1",
    "mineflayer-pathfinder": "^2.4.5",
    "path": "^0.12.7",
    "ping": "^0.4.4",
    "vec3": "^0.1.10"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ovh.vazquezsg.mc-beta",
    "productName": "mc-beta",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!node_modules/minecraft-data/minecraft-data/data/bedrock/**",
      "!node_modules/**/{test,tests,__tests__,example,examples,docs,doc,benchmark,benchmarks,coverage}/**",
      "!node_modules/**/*.map",
      "!mcbeta-context.md",
      "!.git/**"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
